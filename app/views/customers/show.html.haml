.container.mx-auto.px-4.py-8
  .grid.grid-cols-1.md:grid-cols-3.gap-6
    
    / Customer Details Card (Left Column)
    .col-span-1
      .bg-white.border.border-gray-200.rounded-lg.shadow.p-6.dark:bg-gray-800.dark:border-gray-700
        .flex.flex-col.items-center.pb-6
          .w-24.h-24.mb-3.rounded-full.shadow-lg.bg-blue-100.text-blue-600.flex.items-center.justify-center.text-3xl.font-bold.dark:bg-blue-900.dark:text-blue-300
            = @customer.name.first
          %h5.mb-1.text-xl.font-medium.text-gray-900.dark:text-white= @customer.name
          %span.text-sm.text-gray-500.dark:text-gray-400= @customer.email
        
        .flex.justify-center.space-x-3.border-t.border-gray-200.dark:border-gray-700.pt-6
          = link_to 'Edit Profile', edit_customer_path(@customer), class: "inline-flex items-center px-4 py-2 text-sm font-medium text-center text-white bg-blue-700 rounded-lg hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800"
          = link_to 'Back', customers_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-center text-gray-900 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 focus:ring-4 focus:outline-none focus:ring-gray-200 dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-700 dark:focus:ring-gray-700"

    / Order History (Right Column)
    .col-span-1.md:col-span-2
      .bg-white.border.border-gray-200.rounded-lg.shadow.p-6.dark:bg-gray-800.dark:border-gray-700
        %h3.text-xl.font-bold.text-gray-900.dark:text-white.mb-4 Order History
        
        - if @orders.any?
          .relative.overflow-x-auto
            %table.w-full.text-sm.text-left.text-gray-500.dark:text-gray-400
              %thead.text-xs.text-gray-700.uppercase.bg-gray-50.dark:bg-gray-700.dark:text-gray-400
                %tr
                  %th.px-4.py-2 Order ID
                  %th.px-4.py-2 Date
                  %th.px-4.py-2 Status
                  %th.px-4.py-2 Total
              %tbody
                - @orders.each do |order|
                  %tr.border-b.dark:border-gray-700.hover:bg-gray-50.dark:hover:bg-gray-600
                    %td.px-4.py-3
                      = link_to "#%05d" % order.id, order_path(order), class: "text-blue-600 dark:text-blue-500 hover:underline"
                    %td.px-4.py-3= order.created_at.strftime("%b %d, %Y")
                    %td.px-4.py-3
                      %span.text-xs.font-medium.px-2.py-0.5.rounded{class: (order.status == 'Completed' ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300' : 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300')}= order.status
                    %td.px-4.py-3.font-medium.text-gray-900.dark:text-white= number_to_currency(order.total_amount, unit: "₹")
        - else
          %p.text-gray-500.dark:text-gray-400 This customer hasn't placed any orders yet.