.container.mx-auto.px-4.py-8
  .flex.justify-between.items-center.mb-6
    %h1.text-3xl.font-bold.text-gray-900.dark:text-white Customers Information
    -if can? :manage, Customer
      = link_to 'Add Customer', new_customer_path, class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 focus:outline-none dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800"

  .relative.overflow-x-auto.shadow-md.sm:rounded-lg
    %table.w-full.text-sm.text-left.text-gray-500.dark:text-gray-400
      %thead.text-xs.text-gray-700.uppercase.bg-gray-50.dark:bg-gray-700.dark:text-gray-400
        %tr
          %th.px-6.py-3{scope: "col"} Name
          %th.px-6.py-3{scope: "col"} Email
          %th.px-6.py-3{scope: "col"} Date Added
          %th.px-6.py-3{scope: "col"} Actions
      %tbody
        - @customers.each do |customer|
          %tr.bg-white.border-b.dark:bg-gray-800.dark:border-gray-700.hover:bg-gray-50.dark:hover:bg-gray-600
            %th.px-6.py-4.font-medium.text-gray-900.whitespace-nowrap.dark:text-white{scope: "row"}= customer.name
            %td.px-6.py-4= customer.email
            %td.px-6.py-4= customer.created_at.strftime("%b %d, %Y")
            %td.px-6.py-4.flex.space-x-3
              = link_to icon(:eye), customer_path(customer), title: "View Profile", class: "font-medium text-blue-600 dark:text-blue-500 hover:underline"
              = link_to icon(:pencil), edit_customer_path(customer), title: "Edit Profile", class: "font-medium text-yellow-600 dark:text-yellow-500 hover:underline"
              = button_to icon(:trash), customer_path(customer), title: "Delete Profile", method: :delete, data: {turbo_confirm: 'Are you sure?'}, class: "font-medium text-red-600 dark:text-red-500 hover:underline bg-transparent border-0 p-0 cursor-pointer"