.max-w-2xl.mx-auto.mt-10
  .flex.items-center.justify-between.mb-6
    %h1.text-2xl.font-bold.text-gray-900.dark:text-white Edit Team Member
    = link_to "Back to List", admin_users_path, class: "text-sm text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 hover:underline"

  = form_with(model: [:admin, @user], local: true, class: "space-y-6 bg-white p-8 rounded-lg shadow-md border border-gray-200 dark:bg-gray-800 dark:border-gray-700") do |f|
    - if @user.errors.any?
      .p-4.mb-4.text-sm.text-red-800.rounded-lg.bg-red-50.dark:bg-gray-800.dark:text-red-400
        %span.font-medium Please fix the following errors:
        %ul.list-disc.pl-5.mt-2
          - @user.errors.full_messages.each do |message|
            %li= message

    .mb-6
      = f.label :email, "Employee Email", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white"
      = f.email_field :email, class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500", placeholder: "user@example.com", required: true

    .mb-6
      = f.label :role_id, "Assign Role", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white"
      = f.collection_select :role_id, current_user.company.roles, :id, :name, { prompt: "Select Role" }, class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"

    .border-t.border-gray-200.dark:border-gray-700.pt-6.mt-6
      %h3.text-lg.font-medium.mb-4.text-gray-900.dark:text-white Change Password (Optional)
      
      .grid.grid-cols-1.md:grid-cols-2.gap-4.mb-6
        %div
          = f.label :password, "New Password", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white"
          = f.password_field :password, placeholder: "Leave blank to keep current", class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"

        %div
          = f.label :password_confirmation, "Confirm New Password", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white"
          = f.password_field :password_confirmation, class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"

    .flex.justify-end.space-x-3
      = link_to 'Cancel', admin_users_path, class: "text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-200 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-gray-800 dark:text-white dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:border-gray-600 dark:focus:ring-gray-700 transition-colors"
      = f.submit "Update User", class: "cursor-pointer text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800 transition-colors"