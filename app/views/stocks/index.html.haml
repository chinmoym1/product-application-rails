.container.mx-auto.px-4.py-8
  .flex.flex-col.lg:flex-row.justify-between.items-start.lg:items-center.mb-6.gap-4
    %h1.text-3xl.font-bold.text-gray-900.dark:text-white Stocks Inventory Dashboard
    
    .flex.flex-col.sm:flex-row.gap-3.w-full.lg:w-auto.items-center
      = form_with url: stocks_path, method: :get, data: { turbo_frame: "stocks_table", turbo_action: "advance" }, class: "relative w-full sm:w-96" do |f|
        .absolute.inset-y-0.left-0.flex.items-center.pl-3.pointer-events-none
          %svg.w-4.h-4.text-gray-500.dark:text-gray-400{fill: "none", stroke: "currentColor", viewBox: "0 0 24 24"}
            %path{stroke_linecap: "round", stroke_linejoin: "round", stroke_width: "2", d: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"}
        
        = f.text_field :query, value: params[:query], placeholder: "Search by Product Name, Vendor Name, or SKU...", oninput: "this.form.requestSubmit()", class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full pl-10 p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
        = f.submit "Search", class: "hidden"

  = turbo_frame_tag "stocks_table" do
    .relative.overflow-x-auto.shadow-md.sm:rounded-lg
      %table.w-full.text-sm.text-left.text-gray-500.dark:text-gray-400
        %thead.text-xs.text-gray-700.uppercase.bg-gray-50.dark:bg-gray-700.dark:text-gray-400
          %tr
            %th.px-6.py-3{scope: "col"} Product
            %th.px-6.py-3{scope: "col"} SKU
            %th.px-6.py-3{scope: "col"} Location
            %th.px-6.py-3{scope: "col"} Vendors  
            %th.px-6.py-3{scope: "col"} Cost Price       
            %th.px-6.py-3{scope: "col"} Quantity
            %th.px-6.py-3{scope: "col"} Actions
        %tbody
          - @stocks.each do |stock|
            %tr.bg-white.border-b.dark:bg-gray-800.dark:border-gray-700.hover:bg-gray-50.dark:hover:bg-gray-500
              %th.px-6.py-4.font-medium.text-gray-900.whitespace-nowrap.dark:text-white{scope: "row"}= stock.product.name
              %td.px-6.py-4= stock.product.sku
              %td.px-6.py-4= stock.location.presence || "Not Assigned"
              %td.px-6.py-4
                - if stock.vendor
                  %span.font-medium.text-blue-600.dark:text-blue-400= stock.vendor.name
                - else
                  %span.text-gray-400.italic Unknown
              %td.px-6.py-4.font-medium.text-gray-900.dark:text-white
                = number_to_currency(stock.cost_price || 0, unit: "₹")
              %td.px-6.py-4
                - if stock.quantity == 0
                  %span.bg-red-100.text-red-800.text-xs.font-medium.mr-2.px-2.5.py-0.5.rounded.dark:bg-red-900.dark:text-red-300
                    Out of Stock
                - else
                  %span.bg-green-100.text-green-800.text-xs.font-medium.mr-2.px-2.5.py-0.5.rounded.dark:bg-green-900.dark:text-green-300
                    #{stock.quantity} in stock
              %td.px-6.py-4.flex.space-x-3
                = link_to icon(:pencil), edit_stock_path(stock), title: "Update Stock", data: { turbo_frame: "_top" }, class: "font-medium text-blue-600 dark:text-blue-500 hover:underline"
                = button_to icon(:trash), stock_path(stock), title: "Delete Record", method: :delete,form: { data: { turbo_confirm: 'Are you sure?' } }, class: "font-medium text-red-600 dark:text-red-500 hover:underline bg-transparent border-0 p-0 cursor-pointer"
    
    - if @pagy.pages > 1
      .mt-6.flex.justify-center
        = custom_pagy_nav(@pagy)