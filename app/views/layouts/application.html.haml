!!!
%html
  %head
    %meta{content: "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
    %title ProductApp
    %meta{content: "width=device-width,initial-scale=1", name: "viewport"}/
    = csrf_meta_tags
    = csp_meta_tag
    = stylesheet_link_tag "application", "data-turbo-track": "reload"
    = javascript_include_tag "application", "data-turbo-track": "reload", type: "module"
  
  %body.text-gray-900.dark:text-white.bg-gray-50.dark:bg-gray-600
    
    .fixed.top-5.right-5.z-50.flex.flex-col.gap-3
      - flash.each do |key, message|
        - alert_color = key == "notice" ? "bg-green-100 border-green-400 text-green-800 dark:bg-green-900 dark:text-green-300" : "bg-red-100 border-red-400 text-red-800 dark:bg-red-900 dark:text-red-300"
        
        %div{ class: "flex items-center p-4 text-sm rounded-lg border shadow-lg #{alert_color}", role: "alert", data: { controller: "notification" } }
          %span.font-medium= message
          %button.ml-auto.-mx-1.5.-my-1.5.bg-transparent.text-current.rounded-lg.focus:ring-2.focus:ring-gray-400.p-1.5.hover:bg-black.hover:bg-opacity-10.dark:hover:bg-white.dark:hover:bg-opacity-10.inline-flex.h-8.w-8.items-center.justify-center{ type: "button", data: { action: "click->notification#close" } }
            %span.sr-only Close
            %svg.w-5.h-5{ fill: "currentColor", viewBox: "0 0 20 20", xmlns: "http://www.w3.org/2000/svg" }
              %path{ "fill-rule": "evenodd", d: "M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z", "clip-rule": "evenodd" }

    - if user_signed_in?
      .flex.h-screen.overflow-hidden
        
        #sidebar-overlay.fixed.inset-0.bg-gray-900.bg-opacity-50.z-40.hidden.md:hidden{ onclick: "toggleSidebar()" }

        = render 'layouts/sidebar'

        .flex.flex-col.flex-1.w-full.overflow-hidden
          
          = render 'layouts/header'

          %main.flex-1.overflow-y-auto.p-4.md:p-8
            = yield

      :javascript
        window.toggleSidebar = function() {
          const sidebar = document.getElementById('main-sidebar');
          const overlay = document.getElementById('sidebar-overlay');
          
          sidebar.classList.toggle('-translate-x-full');
          if (overlay) overlay.classList.toggle('hidden');

          sidebar.classList.toggle('md:-ml-64');

          const isClosed = sidebar.classList.contains('md:-ml-64');
          localStorage.setItem('sidebarClosed', isClosed);
        };

        window.toggleUserMenu = function(event) {
          if(event) event.stopPropagation();
          const menu = document.getElementById('user-dropdown-menu');
          menu.classList.toggle('hidden');
        };

        document.addEventListener('click', function(event) {
          const menu = document.getElementById('user-dropdown-menu');
          const btn = document.getElementById('user-menu-btn');
          
          if (menu && !menu.classList.contains('hidden') && !btn.contains(event.target) && !menu.contains(event.target)) {
            menu.classList.add('hidden');
          }
        });

        document.addEventListener("turbo:load", () => {
          const sidebar = document.getElementById('main-sidebar');
          if (!sidebar) return; 

          if (localStorage.getItem('sidebarClosed') === 'true') {
            sidebar.classList.add('md:-ml-64');
          } else {
            sidebar.classList.remove('md:-ml-64');
          }
        });
        
    - else
      %main.p-4.md:p-8.min-h-screen.flex.items-center.justify-center
        .w-full.max-w-md
          = yield