!!!
%html
  %head
    %meta{content: "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
    %title ProductApp
    %meta{content: "width=device-width,initial-scale=1", name: "viewport"}/
    = csrf_meta_tags
    = csp_meta_tag
    = stylesheet_link_tag "application", "data-turbo-track": "reload"
    = javascript_include_tag "application", "data-turbo-track": "reload", type: "module"
  
  %body.text-gray-900.dark:text-white.bg-gray-50.dark:bg-gray-600
    - if user_signed_in?
      .flex.h-screen.overflow-hidden
        
        / Mobile Overlay (Darkens the screen when sidebar is open on phones)
        #sidebar-overlay.fixed.inset-0.bg-gray-900.bg-opacity-50.z-40.hidden.md:hidden{ onclick: "toggleSidebar()" }

        / The Left Sidebar
        = render 'layouts/sidebar'

        / The Main Right-Side Column
        .flex.flex-col.flex-1.w-full.overflow-hidden
          
          / The Top Header
          = render 'layouts/header'

          / The Scrollable Content Area
          %main.flex-1.overflow-y-auto.p-4.md:p-8
            - if notice
              .p-4.mb-6.text-sm.text-blue-800.rounded-lg.bg-blue-50.border.border-blue-100.dark:bg-gray-800.dark:text-blue-400.dark:border-gray-700{role: "alert"}
                = notice
            - if alert
              .p-4.mb-6.text-sm.text-red-800.rounded-lg.bg-red-50.border.border-red-100.dark:bg-gray-800.dark:text-red-400.dark:border-gray-700{role: "alert"}
                = alert

            = yield
            
      / The upgraded JS script to handle Desktop + Mobile toggling
      :javascript
        function toggleSidebar() {
          const sidebar = document.getElementById('main-sidebar');
          const overlay = document.getElementById('sidebar-overlay');
          
          // 1. Mobile specific toggles (Slide out and show dark overlay)
          sidebar.classList.toggle('-translate-x-full');
          overlay.classList.toggle('hidden');

          // 2. Desktop specific toggle (Shrink margin to pull content left)
          sidebar.classList.toggle('md:-ml-64');
        }
        
    - else
      %main.p-4.md:p-8.min-h-screen.flex.items-center.justify-center
        .w-full.max-w-md
          - if notice
            .p-4.mb-4.text-sm.text-blue-800.rounded-lg.bg-blue-50.dark:bg-gray-800.dark:text-blue-400{role: "alert"}= notice
          - if alert
            .p-4.mb-4.text-sm.text-red-800.rounded-lg.bg-red-50.dark:bg-gray-800.dark:text-red-400{role: "alert"}= alert
          = yield