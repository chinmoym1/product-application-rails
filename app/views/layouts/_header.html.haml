%header.h-16.bg-white.dark:bg-gray-800.border-b.border-gray-200.dark:border-gray-700.flex.items-center.justify-between.px-4.md:px-6.flex-shrink-0
  
  .flex.items-center
    %button.p-2.mr-3.text-gray-600.rounded-lg.hover:bg-gray-100.dark:text-gray-400.dark:hover:bg-gray-700.focus:ring-2.focus:ring-gray-200.dark:focus:ring-gray-700{ type: "button", onclick: "toggleSidebar()" }
      %span.sr-only Toggle sidebar
      %svg.w-6.h-6{ "aria-hidden" => "true", fill: "none", stroke: "currentColor", viewBox: "0 0 24 24", xmlns: "http://www.w3.org/2000/svg" }
        %path{ d: "M4 6h16M4 12h16M4 18h16", "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2" }
    
    %span.text-lg.font-bold.text-gray-900.dark:text-white.md:hidden Products Manager

  .flex.items-center.space-x-3.md:space-x-6.ml-auto
    .flex.flex-col.text-right
      %span.text-sm.font-bold.text-gray-900.dark:text-white
        = current_user.email
      %span.text-xs.font-black.text-gray-500.dark:text-blue-500.hidden.sm:block
        = current_user.role&.name&.titleize
        
    = link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm font-bold text-red-600 hover:text-red-700 bg-red-50 hover:bg-red-100 dark:bg-red-900/20 dark:text-red-400 dark:hover:bg-red-900/40 px-3 py-2 md:px-4 md:py-2 rounded-lg transition-colors whitespace-nowrap"