%header.h-16.bg-white.dark:bg-gray-900.border-b.border-gray-200.dark:border-gray-800.flex.items-center.justify-between.px-3.sm:px-6.flex-shrink-0
  
  .flex.items-center.gap-3.min-w-0
    %button.p-2.-ml-2.text-gray-500.rounded-lg.hover:bg-gray-100.dark:text-gray-400.dark:hover:bg-gray-800.transition-colors.flex-shrink-0{ type: "button", onclick: "toggleSidebar()" }
      %span.sr-only Toggle sidebar
      %svg.w-5.h-5{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
        %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M4 6h16M4 12h16M4 18h16" }
    
    = link_to root_path, class: "flex items-center gap-2.5 min-w-0" do
      .w-8.h-8.bg-indigo-600.text-white.rounded-lg.flex.items-center.justify-center.flex-shrink-0.shadow-sm
        %svg.w-4.h-4{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
          %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" }
      
      %span.text-base.font-bold.tracking-tight.text-gray-900.dark:text-white.truncate
        = current_user.company&.name || "Products"

  .flex.items-center.gap-3.sm:gap-4.ml-auto.pl-4
    
    .relative
      %button#user-menu-btn.flex.items-center.focus:outline-none{ type: "button", onclick: "toggleUserMenu(event)" }
        
        .h-9.w-9.rounded-full.bg-indigo-50.dark:bg-indigo-900.border.border-indigo-100.dark:border-indigo-800.flex.items-center.justify-center.text-indigo-600.dark:text-indigo-400.font-bold.text-sm.flex-shrink-0.shadow-sm.hover:ring-2.hover:ring-indigo-300.dark:hover:ring-indigo-500.transition-all
          = current_user.email[0].upcase

      #user-dropdown-menu.hidden.absolute.right-0.top-full.mt-3.w-64.bg-white.dark:bg-gray-800.rounded-xl.shadow-xl.border.border-gray-100.dark:border-gray-700.py-3.z-50
        .px-4
          %p.text-sm.font-bold.text-gray-900.dark:text-white.truncate
            = current_user.try(:name).presence || current_user.email.split('@').first.titleize
          %p.text-xs.font-medium.text-gray-500.dark:text-gray-400.truncate.mt-0.5
            = current_user.email
          
          .mt-3.pt-3.border-t.border-gray-100.dark:border-gray-700.flex.items-center.text-xs.font-black
            %span.px-2.py-1.bg-blue-50.dark:bg-blue-900.text-blue-600.dark:text-blue-400.rounded-md
              = current_user.role&.name&.titleize || "User"
            %span.mx-1.text-gray-300.dark:text-gray-600 &bull;
            %span.px-2.py-1.bg-green-50.dark:bg-green-900.text-green-600.dark:text-green-400.rounded-md.truncate.max-w-100px
              = current_user.company&.name&.titleize || "App"

    .h-5.w-px.bg-gray-200.dark:bg-gray-700.hidden.sm:block

    = link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 dark:text-gray-500 dark:hover:text-red-400 dark:hover:bg-red-900/20 rounded-lg transition-all flex-shrink-0" do
      %span.sr-only Sign out
      %svg.w-5.h-5{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
        %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" }