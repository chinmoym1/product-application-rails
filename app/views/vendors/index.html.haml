.container.mx-auto.px-4.py-8
  .flex.justify-between.items-center.mb-6
    %h1.text-3xl.font-bold.text-gray-900.dark:text-white Vendors
    = link_to 'New Vendor', new_vendor_path, class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none dark:focus:ring-blue-800"

  .mb-6.bg-white.p-4.rounded-lg.shadow-sm.border.border-gray-200.dark:bg-gray-800.dark:border-gray-700
    = form_with url: vendors_path, method: :get, data: { turbo_frame: "vendors_table", turbo_action: "advance" }, class: "flex items-center space-x-3" do |f|
      .flex-grow
        = f.text_field :query, value: params[:query], placeholder: "Search by Name or Email...", oninput: "this.form.requestSubmit()", class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
      
      = f.submit "Search", class: "hidden"

  = turbo_frame_tag "vendors_table" do
    .relative.overflow-x-auto.shadow-md.sm:rounded-lg
      %table.w-full.text-sm.text-left.text-gray-500.dark:text-gray-400
        %thead.text-xs.text-gray-700.uppercase.bg-gray-50.dark:bg-gray-700.dark:text-gray-400
          %tr
            %th.px-6.py-3{scope: "col"} Name
            %th.px-6.py-3{scope: "col"} Email
            %th.px-6.py-3{scope: "col"} Phone
            %th.px-6.py-3{scope: "col"} Actions
        %tbody
          - @vendors.each do |vendor|
            %tr.bg-white.border-b.dark:bg-gray-800.dark:border-gray-700.hover:bg-gray-50.dark:hover:bg-gray-500
              %th.px-6.py-4.font-medium.text-gray-900.whitespace-nowrap.dark:text-white{scope: "row"}= vendor.name
              %td.px-6.py-4= vendor.email
              %td.px-6.py-4= vendor.phone
              %td.px-6.py-4.flex.space-x-4
                = link_to icon(:eye), vendor_path(vendor), title: "View Details", data: { turbo_frame: "_top" }, class: "font-medium text-blue-600 dark:text-blue-500 hover:underline"
                = link_to icon(:pencil), edit_vendor_path(vendor), title: "Edit Details", data: { turbo_frame: "_top" }, class: "font-medium text-yellow-600 dark:text-yellow-500 hover:underline"
                = button_to icon(:trash), vendor_path(vendor), title: "Delete Record", method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: "font-medium text-red-600 dark:text-red-500 hover:underline bg-transparent border-0 p-0 cursor-pointer"
    
    - if @pagy.pages > 1
      .mt-6.flex.justify-center
        = custom_pagy_nav(@pagy)