.container.mx-auto.px-4.py-6.max-w-md
  
  .mb-6.text-center
    %h1.text-xl.font-bold.text-gray-900.dark:text-white Account Settings
    %p.mt-1.text-xs.text-gray-500.dark:text-gray-400 Manage your profile details and security.

  .bg-white.dark:bg-gray-800.rounded-2xl.shadow-sm.border.border-gray-200.dark:border-gray-700.overflow-hidden
    
    = form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, multipart: true }) do |f|
      = render "devise/shared/error_messages", resource: resource

      .p-5.sm:p-6.space-y-6
        
        .flex.flex-col.items-center.text-center.pb-6.border-b.border-gray-100.dark:border-gray-700
          .relative.group.mb-4
            - if resource.avatar.attached? && resource.avatar.blob&.persisted?
              = image_tag resource.avatar, class: "h-32 w-32 rounded-full object-cover border-4 border-white dark:border-gray-800 shadow-md transition-transform group-hover:scale-105"
            - else
              .h-32.w-32.rounded-full.bg-indigo-50.dark:bg-indigo-900.flex.items-center.justify-center.text-indigo-600.dark:text-indigo-400.text-5xl.font-bold.border-4.border-white.dark:border-gray-800.shadow-md.transition-transform.group-hover:scale-105
                = resource.email[0].upcase
          
          .space-y-3.w-full.flex.flex-col.items-center
            = f.file_field :avatar, accept: "image/jpg, image/jpeg, image/png, image/gif", class: "block text-xs text-gray-500 dark:text-gray-400 file:mr-3 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 dark:file:bg-indigo-900/30 dark:file:text-indigo-400 transition-colors cursor-pointer w-auto"            
            - if resource.avatar.attached? && resource.avatar.blob&.persisted?
              .flex.items-center.gap-2.mt-1
                = f.check_box :remove_avatar, class: "w-4 h-4 rounded border-gray-300 text-red-600 focus:ring-red-500 dark:border-gray-600 dark:bg-gray-700"
                = f.label :remove_avatar, "Remove photo", class: "text-xs font-medium text-red-600 dark:text-red-400 cursor-pointer hover:underline"

        %div
          = f.label :email, class: "block text-xs font-medium text-gray-900 dark:text-white mb-1.5"
          = f.email_field :email, autocomplete: "email", class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 block w-full p-2.5 dark:bg-gray-700/50 dark:border-gray-600 dark:text-white transition-colors"

        .pt-2
          %div.mb-3
            %h3.text-sm.font-medium.text-gray-900.dark:text-white Change Password
            %p.text-xs.text-gray-500.dark:text-gray-400 (Optional) Leave blank to keep current.
          
          .space-y-3
            %div
              = f.password_field :password, autocomplete: "new-password", placeholder: "New Password", class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 block w-full p-2.5 dark:bg-gray-700/50 dark:border-gray-600 dark:text-white transition-colors placeholder-gray-400 dark:placeholder-gray-500"
            
            %div
              = f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm Password", class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 block w-full p-2.5 dark:bg-gray-700/50 dark:border-gray-600 dark:text-white transition-colors placeholder-gray-400 dark:placeholder-gray-500"

        .pt-4.border-t.border-gray-100.dark:border-gray-700
          .bg-red-50.dark:bg-blue-900.border.border-red-200.dark:border-red-800.rounded-xl.p-4
            = f.label :current_password, "Current Password", class: "block text-xs font-semibold text-gray-900 dark:text-gray-100 mb-1"
            %p.text-11px.text-gray-400.dark:text-white-400.mb-2.5 Required to save any changes.
            = f.password_field :current_password, autocomplete: "current-password", class: "bg-white border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 block w-full p-2.5 dark:bg-gray-900 dark:border-gray-600 dark:text-white transition-colors", required: true

      .bg-gray-50.dark:bg-gray-800.px-5.py-4.border-t.border-gray-200.dark:border-gray-700.flex.items-center.justify-between.rounded-b-2xl
        = link_to "Cancel", root_path, class: "text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
        = f.submit "Save Changes", class: "text-white bg-indigo-600 hover:bg-indigo-700 focus:ring-4 focus:ring-indigo-500/30 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-indigo-500 dark:hover:bg-indigo-400 focus:outline-none transition-all cursor-pointer shadow-sm"