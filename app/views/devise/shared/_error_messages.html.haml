- if resource.errors.any?
  #error_explanation.bg-red-50.dark:bg-red-900.border-l-4.border-red-500.p-4.mb-6.rounded-r-lg.shadow-sm
    .flex.items-start.gap-3
      .flex-shrink-0.mt-0.5
        %svg.h-5.w-5.text-red-500.dark:text-red-400{ viewBox: "0 0 20 20", fill: "currentColor", "aria-hidden" => "true" }
          %path{ "fill-rule" => "evenodd", "clip-rule" => "evenodd", d: "M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" }
      
      .flex-1
        %h3.text-sm.font-semibold.text-red-800.dark:text-red-300
          = I18n.t("errors.messages.not_saved", count: resource.errors.count, resource: resource.class.model_name.human.downcase)
        
        .mt-2.text-sm.text-red-700.dark:text-red-200
          %ul.list-disc.pl-5.space-y-1.marker:text-red-400
            - resource.errors.full_messages.each do |message|
              %li= message