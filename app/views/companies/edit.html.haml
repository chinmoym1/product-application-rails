.max-w-2xl.mx-auto.mt-10
  %h2.text-2xl.font-bold.mb-6 Company Settings

  = form_with(model: @company, url: company_path, local: true, class: "space-y-6") do |f|
    - if @company.errors.any?
      .bg-red-100.text-red-700.p-4.rounded
        = @company.errors.full_messages.to_sentence

    .form-group
      = f.label :name, "Company Name", class: "block text-sm font-medium text-gray-700"
      = f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm"

    .pt-4
      = f.submit "Save Changes", class: "bg-blue-600 text-white px-4 py-2 rounded shadow hover:bg-blue-700"