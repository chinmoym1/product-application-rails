.nested-fields.flex.flex-col.md:flex-row.gap-4.items-end.mb-4.p-4.border.border-gray-200.rounded-lg.bg-gray-50.dark:bg-gray-900.dark:border-gray-700{ data: { new_record: f.object.new_record?.to_s, controller: "product-pricing" } }
  
  = f.hidden_field :_destroy

  .flex-1.w-full
    = f.label :product_id, class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white"
    = f.select :product_id, options_for_select(@products.map { |p| [p.name, p.id, { 'data-price' => p.price }] }, f.object.product_id), { prompt: "Select Product" }, class: "bg-white border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white", data: { action: "change->product-pricing#updatePrice", product_pricing_target: "select" }

  .w-full.md:w-32
    = f.label :quantity, class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white"
    = f.number_field :quantity, min: 1, class: "bg-white border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white"

  .w-full.md:w-40
    = f.label :price_at_purchase, "Unit Price (₹)", class: "block mb-2 text-sm font-medium text-gray-900 dark:text-white"
    = f.text_field :price_at_purchase, readonly: true, tabindex: "-1", class: "bg-gray-200 cursor-not-allowed border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5 dark:bg-gray-800 dark:border-gray-600 dark:placeholder-gray-500 dark:text-gray-400", data: { product_pricing_target: "price" }
  
  .w-full.md:w-auto
    %label.hidden.md:block.mb-2.text-sm &nbsp;
    %button{ type: "button", data: { action: "click->nested-form#remove" }, class: "w-full md:w-auto text-red-600 inline-flex justify-center items-center hover:text-white border border-red-600 hover:bg-red-600 focus:ring-4 focus:outline-none focus:ring-red-300 font-medium rounded-lg text-sm px-4 py-2.5 text-center dark:border-red-500 dark:text-red-500 dark:hover:text-white dark:hover:bg-red-600 dark:focus:ring-red-900" }
      Remove