.container.mx-auto.px-4.py-8.max-w-6xl
  / --- HEADER ---
  .flex.flex-col.md:flex-row.md:justify-between.md:items-start.mb-8.pb-6.border-b.border-gray-200.dark:border-gray-700
    %div
      .flex.items-center.space-x-4.mb-2
        %h1.text-3xl.font-extrabold.text-gray-900.dark:text-white= @product.name
        %span.bg-indigo-100.text-indigo-800.text-xs.font-bold.px-3.py-1.rounded-full.dark:bg-indigo-900.dark:text-indigo-300.uppercase.tracking-wide
          SKU: #{@product.sku}
    
    .flex.items-center.space-x-3.mt-4.md:mt-0
      / BACK BUTTON
      = link_to products_path, class: "inline-flex items-center px-4 py-2.5 text-sm font-medium text-gray-900 bg-gray-100 border border-gray-300 rounded-lg rounded-lg hover:bg-gray-200 focus:ring-1 focus:ring-gray-200 dark:bg-gray-700 dark:text-white dark:hover:bg-gray-600 transition-colors" do
        %svg.w-4.h-4.mr-2{"fill" => "none", "stroke" => "currentColor", "viewBox" => "0 0 24 24"}
          %path{"stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", "d" => "M10 19l-7-7m0 0l7-7m-7 7h18"}
        Back

      / EDIT BUTTON
      = link_to edit_product_path(@product), class: "inline-flex items-center px-4 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg shadow-sm hover:bg-gray-50 focus:ring-1 focus:ring-gray-200 dark:bg-gray-800 dark:text-gray-200 dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:text-white transition-colors" do
        %svg.w-4.h-4.mr-2{"fill" => "none", "stroke" => "currentColor", "viewBox" => "0 0 24 24"}
          %path{"stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", "d" => "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"}
        Edit Product

  .grid.grid-cols-1.lg:grid-cols-3.gap-8
    
    / --- LEFT: CORE PRODUCT IDENTITY (1/3 Width) ---
    .space-y-6.lg:col-span-1
      .bg-white.rounded-2xl.shadow-sm.border.border-gray-200.p-6.dark:bg-gray-800.dark:border-gray-700
        %h2.text-sm.font-bold.text-gray-500.dark:text-gray-400.uppercase.tracking-wider.mb-4 Product Details
        
        %div.mb-6
          %p.text-xs.font-medium.text-gray-500.dark:text-gray-400.mb-1 Selling Price (MSRP)
          %p.text-4xl.font-black.text-gray-900.dark:text-white= number_to_currency(@product.price, unit: "₹")
        
        .pt-6.border-t.border-gray-100.dark:border-gray-700
          %p.text-xs.font-medium.text-gray-500.dark:text-gray-400.mb-2 Description
          .text-sm.text-gray-700.dark:text-gray-300.leading-relaxed
            = @product.description.presence || "No description provided."

    / --- RIGHT: WAREHOUSE DASHBOARD (2/3 Width) ---
    .space-y-6.lg:col-span-2
      .bg-white.rounded-2xl.shadow-sm.border.border-gray-200.overflow-hidden.dark:bg-gray-800.dark:border-gray-700
        
        / Header & KPI
        .p-6.bg-gray-50.dark:bg-gray-800.border-b.border-gray-200.dark:border-gray-700.flex.flex-col.sm:flex-row.justify-between.items-start.sm:items-center.gap-4
          %div
            %h2.text-xl.font-bold.text-gray-900.dark:text-white Warehouse Inventory
            %p.text-sm.text-gray-500.dark:text-gray-400 Total available physical stock
          
          .flex.items-center.space-x-4
            .text-right
              - stock_color = @product.total_quantity > 0 ? 'text-green-600' : 'text-red-500'
              %p.text-3xl.font-black{ class: stock_color }= @product.total_quantity
              %p.text-xs.font-bold.text-gray-500.uppercase Units Total
            
            = link_to new_product_stock_path(@product), class: "inline-flex items-center justify-center px-5 py-2.5 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-lg shadow-sm transition-colors focus:ring-4 focus:ring-blue-300 dark:focus:ring-blue-800" do
              %svg.w-4.h-4.mr-2{"fill" => "none", "stroke" => "currentColor", "viewBox" => "0 0 24 24", "xmlns" => "http://www.w3.org/2000/svg"}
                %path{"stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", "d" => "M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"}
              Receive Shipment

        / LIST OF BATCHES & VENDORS
        .p-6
          %h3.text-xs.font-bold.text-gray-500.uppercase.tracking-wider.mb-4 Active Stock Batches
          
          - if @product.stocks.any?
            .space-y-3
              - @product.stocks.order(created_at: :desc).each do |stock_batch|
                .group.flex.flex-col.sm:flex-row.justify-between.items-start.sm:items-center.p-4.bg-white.rounded-xl.border.border-gray-200.shadow-sm.hover:shadow-md.transition-shadow.dark:bg-gray-800.dark:border-gray-600
                  %div
                    .flex.items-center.space-x-2.mb-1
                      %span.bg-blue-100.text-blue-800.text-xs.font-bold.px-2.py-0.5.rounded.dark:bg-blue-900.dark:text-blue-300
                        = stock_batch.vendor&.name || "Unknown Vendor"
                      %span.text-xs.font-medium.text-gray-400 &bull;
                      %span.text-xs.font-medium.text-gray-500.dark:text-gray-400
                        Rec'd: #{stock_batch.created_at.strftime("%b %d, %Y")}
                    
                    .flex.items-center.space-x-4.text-sm
                      %div.text-gray-700.dark:text-gray-300
                        %span.text-gray-400 Cost:
                        %strong= number_to_currency(stock_batch.cost_price || 0, unit: "₹")
                      %div.text-gray-700.dark:text-gray-300
                        %span.text-gray-400 Loc:
                        %strong #{stock_batch.location.presence || "Main Warehouse"}

                  .mt-4.sm:mt-0.flex.items-center.space-x-4.w-full.sm:w-auto.justify-between
                    %div.text-right.sm:text-left
                      %span.inline-flex.items-center.bg-gray-50.border.border-gray-200.text-gray-800.text-lg.font-bold.px-4.py-1.5.rounded-lg.dark:bg-gray-700.dark:border-gray-600.dark:text-white
                        #{stock_batch.quantity}
                        %span.text-xs.font-normal.text-gray-500.ml-1 units
                    
                    / THE NEW EDIT BUTTON
                    = link_to edit_stock_path(stock_batch), class: "p-2 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors dark:hover:bg-gray-700 dark:hover:text-blue-400", title: "Edit Batch" do
                      %svg.w-5.h-5{"fill" => "none", "stroke" => "currentColor", "viewBox" => "0 0 24 24"}
                        %path{"stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", "d" => "M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"}

          - else
            .py-12.text-center.border-2.border-dashed.border-gray-200.rounded-xl.bg-gray-50.dark:bg-gray-800.dark:border-gray-700
              %svg.mx-auto.h-12.w-12.text-gray-400{"fill" => "none", "stroke" => "currentColor", "viewBox" => "0 0 24 24", "xmlns" => "http://www.w3.org/2000/svg"}
                %path{"stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "1", "d" => "M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"}
              %h3.mt-2.text-sm.font-medium.text-gray-900.dark:text-white No inventory batches
              %p.mt-1.text-sm.text-gray-500.dark:text-gray-400 Get started by logging a new shipment.
              .mt-6
                = link_to new_product_stock_path(@product), class: "inline-flex items-center px-4 py-2 text-sm font-medium text-blue-600 bg-blue-50 border border-blue-200 rounded-lg hover:bg-blue-100 dark:bg-gray-700 dark:border-gray-600 dark:text-blue-400 dark:hover:bg-gray-600" do
                  + Receive Shipment