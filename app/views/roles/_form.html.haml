= form_with(model: @role, local: true, class: "space-y-6") do |f|
  - if @role.errors.any?
    .bg-red-50.text-red-600.p-4.rounded-lg
      %ul
        - @role.errors.full_messages.each do |msg|
          %li= msg

  .mb-4
    = f.label :name, "Role Name (e.g., Manager, Editor)", class: "block mb-2 text-sm font-medium"
    = f.text_field :name, class: "bg-gray-50 border border-gray-300 rounded-lg w-full p-2.5", required: true

  .mb-4
    = f.label :description, "Description", class: "block mb-2 text-sm font-medium"
    = f.text_area :description, class: "bg-gray-50 border border-gray-300 rounded-lg w-full p-2.5"

  .mb-6
    %h3.text-lg.font-medium.mb-3 Assign Permissions
    .grid.grid-cols-1.md:grid-cols-2.gap-4.bg-white.p-4.border.rounded-lg
      = f.collection_check_boxes :permission_ids, Permission.all, :id, :name do |b|
        .flex.items-center
          = b.check_box class: "w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500"
          = b.label class: "ml-2 text-sm font-medium text-gray-900"

  .mt-6
    = f.submit "Save Role", class: "text-white bg-blue-700 hover:bg-blue-800 font-medium rounded-lg text-sm px-5 py-2.5 cursor-pointer"
    = link_to "Cancel", roles_path, class: "ml-4 text-gray-600 hover:underline"
