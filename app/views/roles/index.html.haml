.max-w-6xl.mx-auto.mt-10
  .flex.justify-between.items-center.mb-6
    %h1.text-2xl.font-bold Manage Roles
    = link_to "New Role", new_role_path, class: "text-white bg-blue-600 hover:bg-blue-700 font-medium rounded-lg text-sm px-5 py-2.5"

  .bg-white.rounded-lg.shadow.overflow-hidden
    %table.w-full.text-sm.text-left
      %thead.bg-gray-50
        %tr
          %th.px-6.py-3 Name
          %th.px-6.py-3 Description
          %th.px-6.py-3 Actions
      %tbody
        - @roles.each do |role|
          %tr.border-b
            %td.px-6.py-4.font-medium= role.name
            %td.px-6.py-4= role.description
            %td.px-6.py-4.flex.gap-4
              = link_to "Edit", edit_role_path(role), class: "text-blue-600 hover:underline font-medium"
              
              - if role.name != 'Admin'
                = button_to "Delete", role_path(role), method: :delete, form: { data: { turbo_confirm: 'Are you sure?' } }, class: "text-red-600 hover:underline bg-transparent border-0 p-0 cursor-pointer font-medium"
