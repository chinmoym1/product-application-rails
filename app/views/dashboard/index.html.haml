.container.mx-auto.px-4.py-8.max-w-7xl
  
  .mb-8
    %h1.text-3xl.font-bold.text-gray-900.dark:text-white.tracking-tight
      Welcome back, #{current_user.try(:name).presence || current_user.email.split('@').first.titleize}!
    %p.text-gray-500.dark:text-gray-400.mt-2
      Here you can see the details of your company.

  .grid.grid-cols-1.sm:grid-cols-2.lg:grid-cols-3.xl:grid-cols-4.gap-6
    
    - if can?(:read, Product)
      .bg-white.dark:bg-gray-800.rounded-xl.shadow-sm.border.border-gray-200.dark:border-gray-700.overflow-hidden.flex.flex-col.transition-all.hover:shadow-md
        .p-6.flex-1
          .flex.items-center
            .p-3.rounded-lg.bg-blue-50.dark:bg-blue-900.text-blue-600.dark:text-blue-400
              %svg.w-6.h-6{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
                %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" }
            .ml-4
              %p.text-sm.font-medium.text-gray-500.dark:text-gray-400 Total Products
              %h3.text-2xl.font-bold.text-gray-900.dark:text-white= @products_count || 0
        .bg-gray-50.dark:bg-gray-800.border-t.border-gray-100.dark:border-gray-700.px-6.py-3.mt-auto
          = link_to products_path, class: "flex items-center text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300" do
            View inventory
            %svg.w-4.h-4.ml-1{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
              %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M9 5l7 7-7 7" }

    - if can?(:read, Order)
      .bg-white.dark:bg-gray-800.rounded-xl.shadow-sm.border.border-gray-200.dark:border-gray-700.overflow-hidden.flex.flex-col.transition-all.hover:shadow-md
        .p-6.flex-1
          .flex.items-center
            .p-3.rounded-lg.bg-green-50.dark:bg-green-900.text-green-600.dark:text-green-400
              %svg.w-6.h-6{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
                %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" }
            .ml-4
              %p.text-sm.font-medium.text-gray-500.dark:text-gray-400 Total Orders
              %h3.text-2xl.font-bold.text-gray-900.dark:text-white= @orders_count || 0
        .bg-gray-50.dark:bg-gray-800.border-t.border-gray-100.dark:border-gray-700.px-6.py-3.mt-auto
          = link_to orders_path, class: "flex items-center text-sm font-medium text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300" do
            View orders
            %svg.w-4.h-4.ml-1{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
              %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M9 5l7 7-7 7" }

    - if can?(:read, Stock)
      .bg-white.dark:bg-gray-800.rounded-xl.shadow-sm.border.border-gray-200.dark:border-gray-700.overflow-hidden.flex.flex-col.transition-all.hover:shadow-md
        .p-6.flex-1
          .flex.items-center
            .p-3.rounded-lg.bg-orange-50.dark:bg-orange-900.text-orange-600.dark:text-orange-400
              %svg.w-6.h-6{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
                %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" }
            .ml-4
              %p.text-sm.font-medium.text-gray-500.dark:text-gray-400 Stock Entries
              %h3.text-2xl.font-bold.text-gray-900.dark:text-white= @stocks_count || 0
        .bg-gray-50.dark:bg-gray-800.border-t.border-gray-100.dark:border-gray-700.px-6.py-3.mt-auto
          = link_to stocks_path, class: "flex items-center text-sm font-medium text-orange-600 dark:text-orange-400 hover:text-orange-800 dark:hover:text-orange-300" do
            Manage stock
            %svg.w-4.h-4.ml-1{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
              %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M9 5l7 7-7 7" }

    - if can?(:read, Vendor)
      .bg-white.dark:bg-gray-800.rounded-xl.shadow-sm.border.border-gray-200.dark:border-gray-700.overflow-hidden.flex.flex-col.transition-all.hover:shadow-md
        .p-6.flex-1
          .flex.items-center
            .p-3.rounded-lg.bg-purple-50.dark:bg-purple-900.text-purple-600.dark:text-purple-400
              %svg.w-6.h-6{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
                %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" }
            .ml-4
              %p.text-sm.font-medium.text-gray-500.dark:text-gray-400 Active Vendors
              %h3.text-2xl.font-bold.text-gray-900.dark:text-white= @vendors_count || 0
        .bg-gray-50.dark:bg-gray-800.border-t.border-gray-100.dark:border-gray-700.px-6.py-3.mt-auto
          = link_to vendors_path, class: "flex items-center text-sm font-medium text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300" do
            View vendors
            %svg.w-4.h-4.ml-1{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
              %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M9 5l7 7-7 7" }

    - if can?(:read, Customer)
      .bg-white.dark:bg-gray-800.rounded-xl.shadow-sm.border.border-gray-200.dark:border-gray-700.overflow-hidden.flex.flex-col.transition-all.hover:shadow-md
        .p-6.flex-1
          .flex.items-center
            .p-3.rounded-lg.bg-pink-50.dark:bg-pink-900.text-pink-600.dark:text-pink-400
              %svg.w-6.h-6{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
                %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" }
            .ml-4
              %p.text-sm.font-medium.text-gray-500.dark:text-gray-400 Total Customers
              %h3.text-2xl.font-bold.text-gray-900.dark:text-white= @customers_count || 0
        .bg-gray-50.dark:bg-gray-800.border-t.border-gray-100.dark:border-gray-700.px-6.py-3.mt-auto
          = link_to customers_path, class: "flex items-center text-sm font-medium text-pink-600 dark:text-pink-400 hover:text-pink-800 dark:hover:text-pink-300" do
            View customers
            %svg.w-4.h-4.ml-1{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
              %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M9 5l7 7-7 7" }

    - if current_user.role&.name == 'Admin'
      .bg-white.dark:bg-gray-800.rounded-xl.shadow-sm.border.border-gray-200.dark:border-gray-700.overflow-hidden.flex.flex-col.transition-all.hover:shadow-md
        .p-6.flex-1
          .flex.items-center
            .p-3.rounded-lg.bg-indigo-50.dark:bg-indigo-900.text-indigo-600.dark:text-indigo-400
              %svg.w-6.h-6{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
                %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" }
            .ml-4
              %p.text-sm.font-medium.text-gray-500.dark:text-gray-400 Team Members
              %h3.text-2xl.font-bold.text-gray-900.dark:text-white= @users_count || 0
        .bg-gray-50.dark:bg-gray-800.border-t.border-gray-100.dark:border-gray-700.px-6.py-3.mt-auto
          = link_to admin_users_path, class: "flex items-center text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300" do
            Manage users
            %svg.w-4.h-4.ml-1{ fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" }
              %path{ "stroke-linecap" => "round", "stroke-linejoin" => "round", "stroke-width" => "2", d: "M9 5l7 7-7 7" }