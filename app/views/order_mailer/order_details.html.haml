%html
  %body{style: "font-family: Arial, sans-serif; color: #333; max-w-xl; margin: 0 auto; padding: 20px;"}
    %h2{style: "color: #4F46E5;"} Order Confirmation
    
    %p Hello #{@customer.name},
    %p Thank you for your order! Here are the details of your recent purchase:
    
    %div{style: "background-color: #f9fafb; padding: 15px; border-radius: 8px; margin: 20px 0;"}
      %p
        %strong Order ID:
        #{"%04d" % @order.id}
      %p
        %strong Date:
        = @order.created_at.strftime("%B %d, %Y")
        = @order.created_at.in_time_zone("Asia/Kolkata").strftime("%I:%M %p")
        
    %table{style: "width: 100%; border-collapse: collapse; margin-top: 20px;"}
      %thead
        %tr{style: "border-bottom: 2px solid #e5e7eb; text-align: left;"}
          %th{style: "padding: 10px 0;"} Item
          %th{style: "padding: 10px 0;"} Qty
          %th{style: "padding: 10px 0;"} Unit Price
          %th{style: "padding: 10px 0; text-align: right;"} Total
      %tbody
        - total_amount = 0
        - @order.order_items.each do |item|
          - line_total = item.quantity * item.product.price
          - total_amount += line_total
          %tr{style: "border-bottom: 1px solid #e5e7eb;"}
            %td{style: "padding: 10px 0;"}= item.product.name
            %td{style: "padding: 10px 0;"}= item.quantity
            %td{style: "padding: 10px 0;"}= number_to_currency(item.product.price, unit: "₹")
            %td{style: "padding: 10px 0; text-align: right;"}= number_to_currency(line_total, unit: "₹")
      
      %tfoot
        %tr
          %td{colspan: 3, style: "padding: 15px 0 10px; text-align: right; font-weight: bold;"} Grand Total:
          %td{style: "padding: 15px 0 10px; text-align: right; font-weight: bold; color: #4F46E5; font-size: 1.1em;"}= number_to_currency(total_amount, unit: "₹")

    %p{style: "margin-top: 30px;"} If you have any questions, please reply to this email.